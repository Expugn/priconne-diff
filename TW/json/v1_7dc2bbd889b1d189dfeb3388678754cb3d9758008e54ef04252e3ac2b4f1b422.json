        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":55,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"正式名稱為「邊緣人掰掰團」。這是碧與主角在思考交朋友的方法時所組成的兩人小隊。雖然活動內容多采多姿，但總結來說是為了探討「朋友是什麼」如此宛如哲學般深遠的議題。就這層意義上，或許可以算是一個智慧型集團了。但實際的活動內容還是先別提了。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"BB團","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2024,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
