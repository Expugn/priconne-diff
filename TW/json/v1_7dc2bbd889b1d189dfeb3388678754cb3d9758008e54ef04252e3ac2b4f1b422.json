    "v1_7dc2bbd889b1d189dfeb3388678754cb3d9758008e54ef04252e3ac2b4f1b422": [
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":1,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"由壞人「惡德伊」擔任會長的邪惡商會。放高利貸、綁架、偷渡違法武器，做盡各種邪惡勾當。惡德伊說話雖然客氣，但卻是個大壞蛋。真正的壞人，指的就是他這種人。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"惡德伊商會","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1001,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":2,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":2,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"世界最大的大陸。在大陸的中心有個巨大都市『蘭德索爾』，其中矗立著一座高達天際的索爾之塔。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"阿斯特賴亞大陸","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1002,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":2,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":3,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"稱呼這個世界整體時所使用的單詞。也是阿斯特賴亞大陸的由來。不過，「阿斯特朗」的語源是從何而來，則沒有一個肯定的說法。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"阿斯特朗","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1003,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":4,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"在主角夢中出現的神秘少女。就她的口吻看來，她似乎知道有關主角的過去。特徵是話中帶刺，並有著破損的翅膀。可可蘿將愛梅斯當作是神一樣地崇拜，也接收她所下達的旨意。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"愛梅斯","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1004,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":1000101},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":5,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"修特帕魯的綽號。如同字面上的意思，即使只是走在路上，她也會像龍卷風一般，接二連三地引發各式各樣的事件，所以這麼叫她的人也自然而然的變多了。而本人似乎很喜歡『龍卷風』這個詞，所以用這個綽號叫她的話，她會很開心地回應。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"移動龍卷風","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1005,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":6,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"杏奈的本名。不管對方是誰，都要先報上自己的姓名是杏奈的原則。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"安妮羅潔‧馮‧修特帕魯","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1006,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":8,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"在我這個疾風之冥姬的左眼當中，已經累積了大量的魔力！　當要使出極為強大的魔法時，我的眼睛就會放出這世上絕無僅有的閃耀光輝！","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"魔瞳（Evil‧Eye）","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1007,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":3,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":9,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"莫妮卡在祖國所隸屬的部隊名稱。有白色翅膀之意。為了提升這名字的知名度，莫妮卡每天都很努力地宣傳。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"純白之翼","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1008,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":3,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":10,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"是由公會會長莫妮卡所組成的公會。成員為莫妮卡、妮諾、雪、空花、步未等5人。但與其說是「組成」，還不如說是「不小心組成了」比較正確。成員們總因自己少根筋的行動而引發危機，但她們又會自己華麗地解決掉。所以，這個公會到底該說是充斥著不成材的人，還是潛能無限呢，現在還無法判斷。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"純白之翼 蘭德索爾分部","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1009,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":11,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"名聲響徹阿斯特賴亞大陸，可說是蘭德索爾第一的商家也不為過的知名家族。其中，由於許多為人津津樂道的傳聞，因此他們的千金「秋乃‧紫藤」的名字在蘭德索爾是廣為人知。不論是在好的意思，或是壞的意思上都是。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"紫藤家","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1010,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":2,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":12,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"阿斯特賴亞大陸上最巨大的火山。至今仍頻繁的噴發，再加上有許多魔物棲息於此，是個危險的地區。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"貝利奧火山","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1011,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":2,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":13,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"位於阿斯特賴亞大陸，綠意盎然的街道。由於位處氣候較佳的地域，棲息於此的植物，動物，昆蟲的種類也很多。在這裡散步，就能看到各式各樣的生物。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"埃斯特雷拉街道","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1012,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":14,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"揮舞寄宿在劍上的魔力，將其釋放的魔法。壓縮成高密度的魔力能夠發揮出傲人的威力，光是稍微碰觸到就能讓人體無完膚。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"深淵悠久＝翠翔裂空斬（Eternal Abyss=Divider）","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1013,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":16,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"居住於阿斯特朗的四個種族的其中之一。有著尖尖長長的耳朵是他們外貌的特徵。一般來說，相較於其他種族智力較高，能使用魔法的人也比較多。因為熱愛自然，所以居住於森林裡的人不在少數，但近年來定居於蘭德索爾的人也逐漸增加。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"精靈族","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1014,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":2,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":17,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"位於阿斯特賴亞大陸，自然環境豐富的森林。在整個大陸的精靈族當中，大多生於此處，在出生後即在此與植物、動物等各式各樣的生命進行交流。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"精靈之森","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1015,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":18,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"在棲息於貝利奧火山為數不多的植物當中，最為稀有的植物種類之一。因為非常稀有，因此有著「只要將它送給意上人，即可讓戀情開花」的傳聞。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"結緣之花","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1016,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":2,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":19,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"位於阿斯特賴亞大陸，非常險峻的高山。雖然有條山路與貝利奧火山相連，但是通行的難度實在太高，因此罕有人至。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"歐拉爾高山","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1017,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":20,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"可紀錄聲音，很特殊的魔石。原理是注入魔力後，即可播放紀錄於其中的聲音，被加工成圓盤狀於市面上流通。依據魔石的大小，能播放的時間會有所不同。在過去，若要長時間收聽，就需要有人能持續灌注魔力才行，因此只有貴族與富翁持有。但是在數十年前，開發出能透過儲存魔力的石頭將魔力灌注於音響盤的技術，並以此製造出播放機器後，音響盤便快速地普及了。現在整個裝置的價格變得很合理，任誰都能輕鬆享受收聽音響盤的樂趣。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"音響盤","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1018,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":21,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"【動物苑】的下游組織。同屬【動物苑】的夥伴，主要是保護大家免於魔物威脅的武鬥派公會。也會調查並解決「闇影」之類的異常狀況。與【王宮騎士團】勢如水火，總是相互對立，彼此競爭的狀況也從不間斷。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"哞哞自衛隊","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1019,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":22,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"蘭德索爾內的娛樂設施。可以在此遊玩輪盤、卡牌遊戲等等。無論是要打發時間或是希望一夜致富……匯聚了人們的希望與絕望，每天都十分熱鬧。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"賭場","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1020,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":23,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"由以偶像身份進行單獨活動的望擔任公會長的偶像公會。是個透過唱歌與跳舞（帶著哀傷的心情）戰鬥的公會，舉辦演唱會等表演為其主要的活動內容","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"慈樂之音","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1021,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":24,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"過去被神所封印在世界的背面，記載著這世界的各種法則之操縱術的一本書。修特帕魯將記載於該書當中之術式的一小節刻劃於靈魂，讓儲存於魔瞳裡的魔力不至於溢出。只有在使用大規模魔法時，會使用該術式將魔力灌滿全身。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"盟約外典術式第666（Geass Apocrypho・Tyrant Code）","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1022,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":25,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"為特定目的而活動的人們的團體。在蘭德索爾當中，國民都有隸屬於「公會」的義務。加入某些公會，能享受部份公共設施，而未加入公會的人則可能會遭遇無法獲得社會信用等不少缺點。公會有各式各樣的目的，商業、軍事、文化事業等，支持著蘭德索爾的各種產業。另外，一個人也可以加入多個公會。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"公會","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1023,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":26,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"管理蘭德索爾各公會的公家機關。各公會皆受到管理協會的嚴格管理，要是沒有實際進行活動，就會遭受解散處份。但是，也有像犯罪集團一樣的反社會的非公認公會存在。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"公會管理協會","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1024,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":27,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"組成公會後，賜予蘭德索爾國民們的活動據點。根據公會的活動規模、功績等，可擴充設施或是進行改建。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"公會小屋","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1025,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":28,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"過去曾因採掘水晶而繁榮發展，但現在只是一座完全不見當時榮景的古城，聳立在山裡。知道這段歷史的人很少。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"冰晶山脈","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1026,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":30,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"指的是凡事皆以效率為最優先的人。簡單來說就是像美冬這樣的人。在打電動的時候，會照著攻略本進行攻略的那種類型。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"效率狂","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1027,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":31,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"魔法師所創造出來的彷生命體。會忠實地執行創造主的命令。透過泥土或礦石等物質生成，有著各式各樣的尺寸與能力。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"魔像","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1028,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":32,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"除了魔法相關書籍，還會蒐集小說、文藝作品或是有趣的古代遺產等等，這是走遍各地蒐集了各種東西的七七香獲得的綽號。但本人覺得自己還不配擁有這個綽號。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"收藏家（Collector）","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1029,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":33,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"此為居住於火山的魔物「沙羅曼達」的血液，有著很高的融解能力。腐蝕能力很高，對人體極為有害。就連沙羅曼達自己也可能被自己的血液給侵蝕，導致死亡。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"沙羅曼達之血","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1030,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":34,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"由前【王宮騎士團】的副團長咲戀所統籌與經營的公會。雖然是個孤兒院，但也有在做生意。咲戀在過去護衛王宮時，發現每天都有許多閒暇時間非常浪費，為了能為他人盡一份心力而開始營運。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"咲戀育幼院","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1031,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":35,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"修特帕魯在前世時所隸屬的暗黑騎士團。「暗黑騎士們在過去皆已墮落於罪惡當中。但是為了殲滅要顛覆世界的暗黑存在――《星之審判者》，他們決定使用相同的黑暗力量與其對抗。最後，在與星之審判者的戰鬥中，暗黑騎士們全數滅亡……」（節錄自『冥風戰記』）","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"熾炎戰鬼煉獄血盟暗黑團（The‧Order‧Of‧Gehenna‧Immortals）","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1032,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":36,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"有著人類姿態的特殊魔物。雖然會說人話，但那些也只是由沒有脈絡的單字所組成，因此推測牠們並未擁有智能。在蘭德索爾當中目擊他們的頻率急速飆升，被視為問題。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"闇影","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1033,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":37,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"據說這是要抵達索爾之塔頂端不可或缺的道具，是個半透明的球體。現在已經沒有多少人相信這個傳說，被認為只存在於故事之中。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"索爾魔珠","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1034,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":38,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"聳立於蘭德索爾中心的巨塔。這是阿斯特賴亞大陸上最大的建築物，也是最大的謎團。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"索爾之塔","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1035,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":7,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"鈴的最愛。有時還會將所有的薪水拿去買紅豆麵包。豆沙餡派和紅豆餡派這兩種派別的論戰，已持續多年。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"紅豆麵包","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1036,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":29,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":1,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"是近年製造而成的玩具。可以使用硬體的魔法道具，加上使用了特殊礦石打造的軟體記憶媒體一起玩。因為是以高技術打造而成，因此非常的高價。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"遊戲","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":1037,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":39,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"這是碧蒐集了掉落在精靈之森的鐵皮零件所做出的人偶。被碧拿來當作是交朋友用的練習對象，每天都會跟它說話。通稱「好朋友號」。與好朋友號的對話，基本上都是碧單方面在說話，但是在碧的想像當中，這些對話都是很完美地在進行。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"有我在喔好朋友1號","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2001,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":40,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"據說存在於這世界上某處的地方。在傳說中，這是一個在古代十分繁榮的都市，各種技術也都非常發達。有關暮光之都的傳說不少，像是「可鍛造出絕對不會斷掉的武器的刀匠」、「可來往於各星球間的飛空艇」等等都很有名。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"暮光之都","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2002,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":41,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"能夠實現一般人類無法作到的事的超自然特殊身體能力。不需要進行系統式學習，也不需要詠唱咒文的地方，與魔法不同。截至目前為止，尚未證實有擁有超能力的人類。不過，有收到有人浮在空中的目擊情報，因此造成了那是魔法還是超能力的議論。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"超能力","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2003,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":42,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"阿斯特賴亞大陸所使用，遠距離通訊用的魔法。分別有由隸屬公家機關，或私立團體的魔法師透過經整頓的基礎魔法網路進行通訊，或是透過個人魔法通訊這兩種方法。但不論是哪一種，都是屬於高等魔法，因此精準度並不高，也容易發生障礙。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"通訊魔法","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2004,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":43,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"伊莉亞‧奧恩斯坦與魔族的少女們所組成的公會。這名稱與過去伊莉亞和神明展開大規模對抗時，所率領的魔族最強軍隊的名稱相同。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"惡魔偽王國軍","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2005,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":44,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"有時會以保鏢的身份發揮自己的實力――惠理子的綽號。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"破壞者（Destroyer）","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2007,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":45,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"在太古時代，率領魔族與神明們對抗的魔族女王。雖然在魔族間是很知名的故事，但認為她真的存在的人也為數不少。同時也被稱呼為「傳說的大魔王」「傳說的魔女」等。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"傳說的吸血鬼","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2008,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":46,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"由日和、優衣、怜等 3 人所組成的助人公會。公會長由日和擔任，主要的活動內容就是幫助遇到困難的人。但是她們真正目的是，至今懷抱同樣夢想的 3 個人都想達到的願望，「到達索爾之塔的頂端」。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"破曉之星","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2009,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":47,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"出現在阿斯特賴亞大陸地底的洞穴。由於大多被魔物當成巢穴，所以一般都將其視為危險區域。不過，也會被用來進行違法交易，或是被盜賊當成祕密基地。也有人將其視為死後世界的入口，將其作為墓地來使用。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"洞窟","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2010,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":48,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"獸人們的互助組織公會。居住在蘭德索爾的獸人們幾乎都隸屬於【動物苑】，接受其援助。雖然是個能與【公主騎士】匹敵的大規模公會，但由於每個人的參與意識都比較薄弱，所以沒有人能掌握公會的整體面向。這是無數公會的結合體，還有【哞哞自衛隊】【伊麗莎白牧場】等下游組織。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"動物苑","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2011,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":49,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"妮諾十分嚮往，據說是在蘭德索爾東方的遙遠國度。忍者、武士、藝妓、富士山……據說那裡有著許多充滿異國情懷的事物。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"東國","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2012,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":50,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"尋找暮光之都的人們用來交流各式情報的公會。公會長是流夏。除了流夏以外的成員，幾乎都是擁有綽號的名人，在這些人組成公會之後，便傳出了蘭德索爾最危險的公會出現了的傳言。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"暮光流星群","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2013,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":52,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"可說是【公主騎士】本隊的騎士團公會。他們用「團長」來稱呼公會長。可以說是蘭德索爾的國軍，活動目的是守護「王宮」以及王族，以及接受敕命達成任務。同時，作為守護城鎮治安的警察組織這面也很重要。有著由王侯貴族出任要職的傳統，出身於市民階級的騎士無法進入王宮等制約也很多。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"王宮騎士團","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2014,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
