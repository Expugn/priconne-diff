        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":68,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":3,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"為了剷除兇暴並且威脅著人類生活的魔物，進行驅除與討伐的行為。討伐魔物時，採集到的肉、皮、油脂、骨頭、角、羽毛等等，都會用來製作生活用品，因此也可以將狩獵當作是維持生計的手段之一。另一方面，有時候也會發現不具殘暴生性的魔物，而將其視為變種，並當成保護對象以進行調查。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"討伐魔物","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":3005,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
