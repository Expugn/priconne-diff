        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":75,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":3,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"掌管蘭德索爾施政的君王與其一族。蘭德索爾在傳統上是以國王的長女擔任君主的母系國家。王族居住在王城當中，受到【王宮騎士團】的嚴密保護。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"蘭德索爾王家","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":3012,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":76,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":3,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"就本來的意思而言，指的是在現實生活過得很充實的人。但在衍生意義上，據優花梨所說「最近無論是誰都把這個詞當成是『正在談戀愛的人』在用呢！　我雖然是單身，不過現實生活也過得很充實啊！　嗚嗚……總之你們就快爆炸啦！」以上。無論如何，似乎都非常希望現充爆炸的樣子。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"現充","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":3013,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":77,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":3,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"由美美、禊、鏡華 3 個好朋友所組成的公會。公會的目的就只是一起玩。這並非由公會管理協會正式認可的團體，只是她們三個人在玩公會的扮家家酒遊戲。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"小小甜心","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":3014,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
