        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":80,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":3,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"指的是應該存在的人物的相關紀錄或記憶消失的奇怪現象。例如，小孩子一定有雙親，但即使調查資料也無法證實他們的存在，而小孩子也沒有關於雙親的任何記憶。因為這種奇怪現象的關係，因而造成許多小孩沒有監護人，也無處可去的社會問題。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"消失","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":3017,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":81,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":3,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"聽說過去光是有人從口中說出這個名字，就會讓大陸上的壞人們顫抖不已存在。而其真面目其實是深月。她只是一一擊退阻礙自己研究的人，不知不覺間就獲得了這個名號。據說當她掀開平時遮住左眼的眼罩時，地獄就會降臨。","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"獨眼惡魔（One Eye Devil）","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":3018,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0}
