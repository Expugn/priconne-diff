        {"4c9540b69476fc83972e47bc339833f61e6f8e09c20442f05089484f6c1dbe7f":1,"eb02eb654c6f8be899e9aab33ce57d421964178b3bc15f9bb89b2da672a98a7d":58,"6a453c4287c6a10f06fa2a63d6bcab5f4622cd063892dd96a9495dcad653ee10":2,"ee8e47e42b73e98f4de06ec8a0fe98bda62b02b3177e7bc03bc3784a5fa581d7":"最近在蘭德索爾蔚為話題的神秘美少女義賊。會闖入罪大惡極的壞人家裡偷竊，並將偷到的寶物發送給貧困的百姓們。雖然真正的身份成謎，但珠希曾說「幻、幻影貓的真面目？　我、我不知道喵。不過，我有聽說她是個非常可愛，又很喜歡貓咪的義賊喵。今後也請多多支持幻影貓唷喵！」以上。幻影貓……到底是何許人也呢……","3e48d6b6c02852df74a7eaf1547e4f31d732ea34c7f3bc6601e956063c241951":"幻影貓","6507aa7262ee52bccfd2b5a43d5b2568ed8a5ec498ea8afcfa996be618148a8f":2019,"fa00064a23be9e761e5a2c72332dcebfe06bda97061b6d2e6a034e62c6418082":0},
