    "v1_ad6eb80154db182389adbe1519e70179997172883349a79f18790985f6a4fefc": [
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":1,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"這是猜謎遊戲，要回答空有五個字的謎題。\\n組成五人隊伍互相合作，每一人都要回答一個字。\\n謎題有各式各樣的種類哦。","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":100901,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1009,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":1},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":2,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"總共有兩種遊玩模式可以享受這個小遊戲。\\n若想挑戰您自身的實力，請選擇和CPU一起遊玩的單人模式；\\n想和夥伴合作遊玩的話，請您選擇多人模式。","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":100902,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1009,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":1},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":3,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"提示將會隨機顯現。\\n如果想進一步取得提示的話，就使用「提示鈕」吧。\\n使用次數有上限的樣子，所以胡亂浪費是「壞壞」的喔。","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":100903,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1009,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":1},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":4,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"出過的謎題可以使用「題庫」功能進行回顧。\\n解放題目並填滿題庫，就可以取得限定稱號等獎勵，\\n一面好好地複習，一面持續不懈地挑戰謎題吧。","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":100904,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1009,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":1},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":5,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"要我教你學習？真拿你沒辦法……\\n就用問答方式輕鬆學習喔！選擇和我或鈴奈一同讀書吧。\\n要跟鈴奈一起挑戰的話，你就要好好教她喔！","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":100905,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1012,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":1},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":6,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"題目會從3種形式中隨機挑選。\\n「單選題」和「複選題」可以使用一定次數的提示！\\n在什麼時候使用提示將會成為提升成績的關鍵。","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":100906,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1012,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":1},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":7,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"出過的題目會被記錄在「題庫」中！\\n複習時靠這個就沒問題了呢。聽說讓題庫裡填滿題目就能得到稱號，\\n讓我們幹勁十足地以蒐集完成為目標吧！","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":100907,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1012,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":1},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":8,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"在滿足條件後解放的「深度模式」中，\\n可以在時間限制內挑戰自己能回答多少題目！\\n這是個能檢視你成長後有多少實力的好機會！加油吧！","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":100908,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1012,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":2},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":9,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"為了獲得獎金，要去參加那個「戰車戰鬥大會」喔！\\n就讓我們來組裝出最棒的戰車，去打倒其他所有人吧。","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":101401,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1014,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":1},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":10,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"戰車之間的戰鬥似乎會以全自動的方式進行呢。\\n……那麼我們搭乘進去沒有意義？哼，你在說什麼啊？\\n搭乘者擁有的技術會左右勝負這點，你要銘記在心啊。","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":101402,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1014,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":1},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":11,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"勝負時間要是拖太久，戰車會被從左右逼近的牆壁夾扁喔。\\n然後規則上，戰車被彈出畫面外也算輸。\\n這刺激的感覺還挺有趣的呢。","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":101403,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1014,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":1},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":12,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"聽說「冒險」模式總共要挑戰50個關卡的戰鬥喔。\\n哦……也可以跟各個世界的公主們戰鬥嗎。在向她們雪恥的同時，\\n也順便搶走能用在戰車上的零件吧。","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":101404,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1014,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":2},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":13,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"咦～什麼～？雜碎哥哥想要戰車的零件嗎～？\\n那麼～如果你拼命求我的話，我可以考慮看看喔～♡\\n居然像小女孩低頭懇求東西～真的是有夠遜的啦～ｗ","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":101405,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1014,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":3},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":14,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"我先說在前面～就算是沒有自尊心的雜碎哥哥，也不可以\\n無限度地懇求我喔♡在我有那個心情之前～你要好好等待喔♪\\n啊，但是你讓我分解不需要的零件之類的話，我可能就會有那個心情喔♡","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":101406,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1014,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":3},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":15,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"在這邊～可以組裝擁有的零件來自訂自己的戰車喔～\\n所以說，雜碎哥哥你就組台雜碎雜碎號看看吧～？\\n為了讓它變成一台帥氣的雜碎雜碎號，你就加油吧♡加油吧♡","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":101407,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1014,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":4},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":16,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"戰車這東西，是透過將其他零件裝到作為基底的軀體來完成的。\\n因為每個軀體能裝零件的地方都不一樣，\\n所以先確認每個軀體被設定的可以裝零件的位置開始比較好吧？","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":101408,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1014,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":4},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":17,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"啊，對了對了。軀體能組裝上去的零件的COST是有上限的～\\n是沒辦法裝上超過上限的武器或是小機件的喔～\\n不過雜碎哥哥沒辦法計算吧～♡要我來幫你算嗎？","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":101409,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1014,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":4},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":18,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"戰車上～可以讓１個隊長跟２個隊員，總計３個人搭乘喔。\\n因為戰車的力量也會因為搭乘的人不同改變，\\n所以要好好挑選比較好喔～哥哥你會選我對吧～？","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":101410,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1014,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":4},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":19,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"在「對手對戰」好像可以挑戰各種人們造出來的戰車。\\n獲得很多勝利，累積點數的話可以從任務獲得獎勵，\\n所以要加油才行……為了獲得晚餐的配菜……！","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":101411,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1014,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":5},
        {"d8a56633f5fcebe0d738947230720e49fad50b5851d2337f52a6db5bf9a99649":20,"1b59d28d624247056a10c52d696d0d4abd85dfda2e6971c156be7fd4270e2e18":"在「與夥伴對戰」似乎可以跟好友還有戰隊成員們對戰。\\n請、請各位手下留情喔……\\n……咦～！？布武機，不要拿我當目標啦～！？","5e6eb5f2bf6e9c87a3cbe1dbd4f30504849605b96a811ff8031f69e0437c8cea":101412,"f89402ca74a466b7ff6dd653d986ff6e4442a34c5f353ddfcb9c137d566ee9f0":1014,"01421238b0302ed778e70dfd8955ea4328a713095d95773cfc40c84c58df5d6f":6}
