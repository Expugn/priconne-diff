        {"b022c544363a0f7249c68ec9656fb48dbfcfd35d28db52ed6289ab76675b4973":"一定時間が経過するごとに、敵、味方全体のＴＰを中回復させる。","480261937a06c83ba09225a6bcb090ec8d1f4c84faa86b3fecea5251fc167744":2017,"60ff6a88744d772f61f0c0b10b88e316da04000ff370b7d44f8b34418b3da78e":146,"0325dff868d464d9d522c8311f93d0f61a8df488ec699ad48d06c973f0645a5d":"百花繚乱"},
