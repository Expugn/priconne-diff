        {"4b3008f5f70630de04ef01df3f18a64096bc19d77888c7dd51d63a92b9ea5286":2017,"c8dc7e6c51ca35c1c0d93f0d0dbcb1da02263ec764b3c1c6479347f43ac05719":"忌火","8b0448b55f5c29a3f938e98251e76b37b0a38a373ceb2de7d29c17c5c63793f6":207,"6b27f9b487b777389208cd29aa6a861623ea36fb21bcb7f6024320ae51da342c":"継続ダメージを与える状態異常のダメージの発生間隔と効果時間が延長される。"},
